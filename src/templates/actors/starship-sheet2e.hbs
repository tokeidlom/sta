<form class="character-sheet" autocomplete="off">
  <div class="split-section">
    <div class="top-left-column">
      <div class="image-field">
        <img class="profile-img" src="{{img}}" data-edit="img" title="{{name}}" />
      </div>
    </div>

    <div class="top-right-column">
      <div class="name-field">
        <div class="title">{{localize 'sta.actor.starship.name'}}</div>
        <input name="name" class="text-entry" type="text" value="{{name}}" placeholder="{{localize 'sta.actor.starship.name'}}" />
      </div>

                        <div class="title">
                            {{localize 'sta.actor.starship.reservepower'}}:
                        </div>
							<input class="checkbox" type="checkbox" name="system.reservepower" data-dtype="Boolean" {{checked system.reservepower}}>

                        <div class="tracktitle">
                            {{localize 'sta.actor.starship.crew'}}
                        </div>
                        <div class="track">
                            <input type="hidden" id="total-crew" name="system.crew.value" value="{{system.crew.value}}" data-dtype="Number" />
                            <input type="hidden" id="max-crew" name="system.crew.max" value="{{system.crew.max}}" data-dtype="Number" />
                            <div class="bar">
                                <div id="bar-crew-renderer" class="bar"></div>
                            </div>
                        </div>


                        <div class="tracktitle">
                            {{localize 'sta.actor.starship.shields'}}
                        </div>
                        <div class="track">
                            <input type="hidden" id="total-shields" name="system.shields.value" value="{{system.shields.value}}" data-dtype="Number" />
                            <input type="hidden" id="max-shields" name="system.shields.max" value="{{system.shields.max}}" data-dtype="Number" />
                            <div id="bar-shields-renderer" class=" bar"></div>
                        </div>



    </div>
  </div>
  <div class="split-section">
    <div class="bottom-left-column">

      <div class="attribute-block">
                        <div class="title">
                            {{localize 'sta.actor.starship.system.title'}}
                        </div>
                        <div class="stat header row">
                            <div class="selector-space"></div>
                            <div class="text secondary-title">{{localize 'sta.actor.starship.system.name'}}</div>
                            <div class="field secondary-title">{{localize 'sta.actor.attdis.mod'}}</div>
                            <div class="field secondary-title">{{localize 'sta.actor.starship.system.breaches'}}</div>
                        </div>
                        {{#each system.systems as |system key|}}
                        <div class="stat row">
                            <input class="selector system" id="{{key}}.selector" type="checkbox" name="system.systems.{{key}}.selected" data-dtype="Boolean" {{checked system.selected}}>
                            <div class="text list-entry"> {{localize system.label}} </div>
                            <input class="field numeric-entry" id="{{key}}" name="system.systems.{{key}}.value" type="number" value="{{system.value}}" />
                            <input class="field numeric-entry breaches" id="{{key}}.breaches" name="system.systems.{{key}}.breaches" type="number" value="{{system.breaches}}" />
                        </div>
                        {{/each}}
</div>
      <div class="discipline-block">
                        <div class="title">
                            {{localize 'sta.actor.starship.department.title'}}
                        </div>
                        <div class="stat header row">
                            <div class="field secondary-title">{{localize 'sta.actor.attdis.mod'}}</div>
                            <div class="text secondary-title">{{localize 'sta.actor.starship.department.name'}}</div>
                            <div class="selector-space"></div>
                        </div>
                        {{#each system.departmentorder2e as |key|}}
                        {{#with (lookup ../system.departments key)}}
                        <div class="stat row">
                            <input class="field numeric-entry" id="{{key}}" name="system.departments.{{key}}.value" type="text" value="{{value}}" placeholder="Name" />
                            <div class="text list-entry"> {{localize label}} </div>
                            <input class="selector department" id="{{key}}.selector" type="checkbox" name="system.departments.{{key}}.selected" data-dtype="Boolean" {{checked selected}}>
                        </div>
                        {{/with}}
                        {{/each}}
</div>

                    <div class="section scale2e">
                        <div class="title">
                            {{localize 'sta.actor.starship.scale'}}:
                        </div>
                        <input class="field numeric-entry" name="system.scale" id="scale" type="number" value="{{system.scale}}" />
                    </div>
                    <div class="section resistance">
                        <div class="title">
                            {{localize 'sta.actor.starship.resistance'}}:
                        </div>
                        <input class="field numeric-entry" name="system.resistance" id="resistance" type="number" value="{{system.resistance}}" />
                    </div>
					
					
                        <div class="check-button btn attribute">{{localize 'sta.actor.attdis.task'}}</div>

                    <div class="section shaken">
                        <div class="title">
                            {{localize 'sta.actor.starship.shaken'}}:
                        </div>
                        <input class="checkbox" type="checkbox" name="system.shaken" data-dtype="Boolean" {{checked system.shaken}}>
                    </div>
      <div class="stressmod">
                        {{localize 'sta.actor.starship.shieldcrewmod'}}
                        <input class="text-entry" name="system.shieldmod" id="shieldmod" type="number" value="{{system.shieldmod}}" placeholder="0" />
	  {{localize 'sta.actor.starship.shieldcrewmod'}}
                        <input class="text-entry" name="system.crwmod" id="crwmod" type="number" value="{{system.crwmod}}" placeholder="0" />
      </div>

</div>
<div class="bottom-right-column">

<div class="row">

            <div class="column designation">
              <div class="title">{{localize 'sta.actor.starship.designation'}}</div>
              <input name="system.designation" class="text-entry" type="text" value="{{system.designation}}" placeholder="{{localize 'sta.actor.starship.designation'}}" />
            </div>
            <div class="column spaceframe">
              <div class="title">{{localize 'sta.actor.starship.spaceframe'}}</div>
              <input name="system.spaceframe" class="text-entry" type="text" value="{{system.spaceframe}}" placeholder="{{localize 'sta.actor.starship.spaceframe'}}" />
            </div>


</div>

<div class="row">
            <div class="column servicedate">
              <div class="title">{{localize 'sta.actor.starship.servicedate'}}</div>
              <input name="system.servicedate" class="text-entry" type="text" value="{{system.servicedate}}" placeholder="{{localize 'sta.actor.starship.servicedate'}}" />
            </div>
            <div class="column missionprofile">
              <div class="title">{{localize 'sta.actor.starship.missionprofile'}}</div>
              <input name="system.missionprofile" class="text-entry" type="text" value="{{system.missionprofile}}" placeholder="{{localize 'sta.actor.starship.missionprofile'}}" />
            </div>
            <div class="column refit">
              <div class="title">{{localize 'sta.actor.starship.refit'}}</div>
              <input name="system.refit" class="text-entry" type="text" value="{{system.refit}}" placeholder="{{localize 'sta.actor.starship.refit'}}" />
            </div>
</div>
<div class="row">
            <div class="column traits">
              <div class="title">{{localize 'sta.actor.starship.traits'}}</div>
              <input name="system.traits" class="text-entry" type="text" value="{{system.traits}}" placeholder="{{localize 'sta.actor.starship.traits'}}" />
            </div>
</div>


                        <div class="title">
                            {{localize 'sta.item.talent.title'}}
                        </div>
                        <div class="header row item">
                            <div class="image"></div>
                            <div class="one-column-with-roll secondary-title">{{localize 'sta.item.genericitem.name'}}</div>
                            <a class="control create" title="Create item" data-type="talent"><i class="fas fa-plus"></i></a>
                        </div>
                        {{#each items as |item id|}}
                        {{#if (eq item.type "talent")}}
                        <li class="row entry" data-item-id="{{item.id}}" data-item-type="{{item.type}}" data-item-value="{{item.name}}">
                            <div class="image"><img class="chat" src="{{item.img}}" title="{{item.name}}"/></div>
                            <div class="one-column-no-roll list-entry talent-tooltip-clickable" id="talent-tooltip-clickable-{{item.id}}" data-talent-name="{{item.name}}">{{item.name}}</div>
                            <div class="control">
                                <a class="edit" title="Edit Item"><i class="fas fa-edit"></i></a>
                                <a class="delete" title="Delete Item"><i class="fas fa-trash"></i></a>
                            </div>
                        </li>
                        <li class="row entry talent-tooltip-container hide" id="talent-tooltip-container-{{item.id}}">
                            <div class="list-entry talent-tooltip-text" id="talent-tooltip-text-{{item.id}}">{{item.system.description}}</div>
                        </li>
                        {{/if}}
                        {{/each}}


                        <div class="title">
                            {{localize 'sta.actor.starship.values'}}
                        </div>
                        <div class="header row item">
                            <div class="image"></div>
                            <div class="one-column-with-roll">{{localize 'sta.item.genericitem.name'}}</div>
                            <a class="control create" title="Create item" data-type="value"><i class="fas fa-plus"></i></a>
                        </div>
                        {{#each items as |item id|}}
                        {{#if (eq item.type "value")}}
                        <li class="row entry" data-item-id="{{item.id}}" data-item-type="{{item.type}}" data-item-value="{{item.name}}">
                            <div class="image"><img class="chat" src="{{item.img}}" title="{{item.name}}"/></div>
                            <h4 class="one-column-with-roll list-entry">{{item.name}}</h4>
                            <div class="control">
                                <a class="edit" title="Edit Item"><i class="fas fa-edit"></i></a>
                                <a class="delete" title="Delete Item"><i class="fas fa-trash"></i></a>
                            </div>
                        </li>
                        {{/if}}
                        {{/each}}


                        <div class="title">
                            {{localize 'sta.actor.starship.launchbay'}}
                        </div>
                        <div class="header row item">
                            <div class="image"></div>
                            <div class="two-column-with-roll-primary">{{localize 'sta.item.genericitem.name'}}</div>
                            <div class="two-column-with-roll-secondary">{{localize 'sta.actor.belonging.other.qty'}}</div>
                            <a class="control create" title="Create item" data-type="smallcraftcontainer"><i class="fas fa-plus"></i></a>
                        </div>
                        {{#each items as |item id|}}
                        {{#if (eq item.type "smallcraftcontainer")}}
                        <li class="row entry" data-item-id="{{item.id}}" data-item-child-id="{{item.system.child}}" data-item-type="{{item.type}}" data-item-value="{{item.name}}">
                            <div class="image"><img class="click-to-nav" src="{{item.img}}" title="{{item.name}}"/></div>
                            <h4 class="two-column-with-roll-primary list-entry">{{item.name}}</h4>
                            <h4 class="two-column-with-roll-secondary list-entry">{{item.system.quantity}}</h4>
                            <div class="control">
                                <a class="edit" title="Edit Item"><i class="fas fa-edit"></i></a>
                                <a class="delete" title="Delete Item"><i class="fas fa-trash"></i></a>
                            </div>
                        </li>
                        {{/if}}
                        {{/each}}


                        <div class="title">
                            {{localize 'sta.actor.note.title'}}
                        </div>
                        <div class="header row item">
                            <div class="one-column-no-roll" style="height:17px;"></div>
                        </div>
                        <div class="note">
                            {{editor system.notes target="system.notes" button=true owner=owner editable=true}}
                        </div>


                        <div class="title">
                            {{localize 'sta.actor.starship.damage'}}
                        </div>
                        <div class="header row item">
                            <div class="one-column-no-roll secondary-title">{{localize 'sta.item.genericitem.name'}}</div>
                            <a class="control create" title="Create item" data-type="injury"><i class="fas fa-plus"></i></a>
                        </div>
                        {{#each items as |item id|}}
                        {{#if (eq item.type "injury")}}
                        <li class="row entry" data-item-id="{{item.id}}" data-item-type="{{item.type}}" data-item-value="{{item.name}}">
                            <div class="image"><img class="chat" src="{{item.img}}" title="{{item.name}}"/></div>
                            <div class="one-column-no-roll list-entry injury-tooltip-clickable" id="injury-tooltip-clickable-{{item.id}}" data-injury-name="{{item.name}}">{{item.name}}</div>
                            <div class="control">
                                <a class="edit" title="Edit Item"><i class="fas fa-edit"></i></a>
                                <a class="delete" title="Delete Item"><i class="fas fa-trash"></i></a>
                            </div>
                        </li>
                        <li class="row entry injury-tooltip-container hide" id="injury-tooltip-container-{{item.id}}">
                            <div class="list-entry injury-tooltip-text" id="injury-tooltip-text-{{item.id}}">{{item.system.description}}</div>
                        </li>
                        {{/if}}
                        {{/each}}



                        <div class="title">
                            {{localize 'sta.actor.starship.equipment'}}
                        </div>
                        <div class="header row item">
                            <div class="image"></div>
                            <div class="two-column-with-roll-primary">{{localize 'sta.actor.belonging.weapon.title'}}</div>
                            <div class="two-column-with-roll-secondary">{{localize 'sta.actor.belonging.weapon.dmg'}}</div>
                            <a class="control create" title="Create item" data-type="starshipweapon2e"><i class="fas fa-plus"></i></a>
                        </div>
                        {{#each items as |item type id|}}
                        {{#if (eq item.type "starshipweapon2e")}}
                        <li class="row entry" id="starship-weapon-{{@index}}" data-item-id="{{item.id}}" data-item-type="{{item.type}}" data-item-value="{{item.name}}" data-item-damage="{{item.system.damage}}" data-item-includescale="{{item.system.includescale}}">
                          <div class="image"><img class="chat" src="{{item.img}}" title="{{item.name}}" data-item-name="{{item.name}}"/></div>
                            <h4 class="two-column-with-roll-primary list-entry">{{item.name}}</h4>
                            <h4 class="two-column-with-roll-secondary list-entry damage">{{item.system.damage}}</h4>
                            <div class="control">
                                <a class="edit" title="Edit Item"><i class="fas fa-edit"></i></a>
                                <a class="delete" title="Delete Item"><i class="fas fa-trash"></i></a>
                            </div>
                        </li>
                        {{/if}}
                        {{/each}}
                        <div class="header row item">
                            <div class="image"></div>
                            <div class="two-column-with-roll-primary">{{localize 'sta.actor.starship.belonging.other.title'}}</div>
                            <div class="two-column-with-roll-secondary">{{localize 'sta.actor.belonging.other.qty'}}</div>
                            <a class="control create" title="Create item" data-type="item"><i class="fas fa-plus"></i></a>
                        </div>
                        {{#each items as |item type id|}}
                        {{#if (eq item.type "item")}}
                        <li class="row entry" data-item-id="{{item.id}}" data-item-type="{{item.type}}" data-item-value="{{item.name}}">
                            <div class="image"><img class="chat" src="{{item.img}}" title="{{item.name}}"/></div>
                            <h4 class="two-column-with-roll-primary list-entry">{{item.name}}</h4>
                            <h4 class="two-column-with-roll-secondary list-entry">{{item.system.quantity}}</h4>
                            <div class="control">
                                <a class="edit" title="Edit Item"><i class="fas fa-edit"></i></a>
                                <a class="delete" title="Delete Item"><i class="fas fa-trash"></i></a>
                            </div>
                        </li>
                        {{/if}}
                        {{/each}}


    </div>
	</div>
</form>